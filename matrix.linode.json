{
  "_comment": "Dev/functional matrix for a single-vCPU Linode (Ubuntu 24.04). Only libzmq is exercised because it is the one target with a working socket loop today, and only the throughput kind is wired in the runnable path. On 1 vCPU the producer and consumer share the core, so these numbers validate the harness mechanics, not engine performance. cpuset.cpus=0 is the only core available.",
  "isolation": {
    "cpuset_cpus": "0",
    "cpuset_mems": "0",
    "memory_max_bytes": 268435456
  },
  "entries": [
    {
      "target": {
        "id": "libzmq",
        "binary": "targets/libzmq_cpp_target/build/libzmq_target",
        "knobs": { "sndhwm": "1000", "rcvhwm": "1000", "io_threads": "1" }
      },
      "transport": "ipc",
      "kind": "throughput",
      "payload_bytes": 64,
      "messages": 200000,
      "warmup_messages": 20000
    },
    {
      "target": {
        "id": "libzmq",
        "binary": "targets/libzmq_cpp_target/build/libzmq_target",
        "knobs": { "sndhwm": "1000", "rcvhwm": "1000", "io_threads": "1" }
      },
      "transport": "tcp_netns",
      "kind": "throughput",
      "payload_bytes": 64,
      "messages": 200000,
      "warmup_messages": 20000
    },
    {
      "target": {
        "id": "libzmq",
        "binary": "targets/libzmq_cpp_target/build/libzmq_target",
        "knobs": { "sndhwm": "1000", "rcvhwm": "1000", "io_threads": "1" }
      },
      "transport": "ipc",
      "kind": "throughput",
      "payload_bytes": 1024,
      "messages": 200000,
      "warmup_messages": 20000
    },
    {
      "target": {
        "id": "libzmq",
        "binary": "targets/libzmq_cpp_target/build/libzmq_target",
        "knobs": { "sndhwm": "1000", "rcvhwm": "1000", "io_threads": "1" }
      },
      "transport": "ipc",
      "kind": "latency",
      "payload_bytes": 64,
      "messages": 20000,
      "warmup_messages": 2000
    },
    {
      "target": {
        "id": "libzmq",
        "binary": "targets/libzmq_cpp_target/build/libzmq_target",
        "knobs": { "sndhwm": "1000", "rcvhwm": "1000", "io_threads": "1" }
      },
      "transport": "tcp_netns",
